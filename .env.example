# Discord Bot Token（必填）
DISCORD_TOKEN=

# （可选但强烈建议）用于“仅在指定服务器快速同步指令”（开发期/多服务器部署非常有用）
# 可填写多个服务器 ID，用英文逗号、空格或分号分隔。
# 填写后只同步到这些服务器，并清理旧的全局命令，通常重启后很快可见。
# 不填则走全局指令同步（可能需要等待较久才会在 Discord 客户端出现）。
# 示例：COMMAND_GUILD_IDS=111111111111111111,222222222222222222
COMMAND_GUILD_IDS=

# 兼容旧配置：只填一个服务器 ID 时也可以继续使用 COMMAND_GUILD_ID。
COMMAND_GUILD_ID=
# SQLite 数据库文件路径
DB_PATH=data/court.db

# -------------------- 小型 VPS 资源控制（可选） --------------------
# Discord.py 消息缓存数量。单服务器建议 100~300；越小越省内存。
BOT_MAX_MESSAGE_CACHE=200

# 同时执行的归档数量。建议保持 1，避免多个归档叠加占用内存。
ARCHIVE_CONCURRENCY=1

# 归档离线保存预算。0 表示不限制，保持完整离线归档能力。
ARCHIVE_MEDIA_BUDGET_MB=0

# 单张图片离线上限。0 表示不限制，保持完整离线归档能力。
ARCHIVE_SINGLE_IMAGE_MAX_MB=0

# -------------------- 常态通过名单 API（可选，默认关闭） --------------------
# 启用后 Bot 会在同一进程内启动只读 HTTP API，建议只监听 127.0.0.1，
# 再用 Cloudflare Tunnel 将域名转发到 http://127.0.0.1:8787。
APPROVED_API_ENABLED=false
APPROVED_API_HOST=127.0.0.1
APPROVED_API_PORT=8787

# 逗号/空格/分号分隔。启用 API 时必填；其他 Bot 请求时使用：
# Authorization: Bearer <token>
APPROVED_API_TOKENS=

# 单次通过名单查询最大返回数量，上限会被程序限制到 1000。
APPROVED_API_MAX_LIMIT=500

# 说明：本项目不再通过 .env “写死”审核频道/分类/Forum/监察频道等。
# 请在服务器内由管理员执行：/议诉 设置、/监察 设置 来完成配置（会写入 SQLite）。
